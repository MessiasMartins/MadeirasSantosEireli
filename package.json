{
  "name": "mdsantos",
  "version": "2.0.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "node scripts/tests/site-validation.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "postcss": "8.5.12",
    "react": "19.2.5",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.4",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md)": [
      "prettier --write"
    ]
  }
}
